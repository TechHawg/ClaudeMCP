# ──────────────────────────────────────────────
# Betting MCP Server — Environment Variables
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# ── Search APIs ──────────────────────────────
# Brave Search API — Free tier: 2,000 queries/month
# https://brave.com/search/api/
BRAVE_API_KEY=

# Perplexity Sonar API — Pay-per-query, ~$5/1000 queries for sonar
# https://docs.perplexity.ai/
PERPLEXITY_API_KEY=

# Tavily API — Free tier: 1,000 API calls/month
# https://tavily.com/
TAVILY_API_KEY=

# ── Odds & Betting APIs ─────────────────────
# The Odds API — Free tier: 500 requests/month
# https://the-odds-api.com/
THE_ODDS_API_KEY=

# OddsJam API — Paid, starts at $99/month for API access
# https://oddsjam.com/odds-api
ODDSJAM_API_KEY=

# ActionNetwork API — Public endpoints free, premium data paid
# https://actionnetwork.com/
ACTION_NETWORK_API_KEY=

# SportsRadar API — Free trial: 1,000 calls/month per sport
# https://developer.sportradar.com/
SPORTRADAR_API_KEY=

# ── Context Data APIs ────────────────────────
# OpenWeatherMap — Free tier: 1,000 calls/day
# https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Rotowire API — Paid, contact for pricing
# https://www.rotowire.com/
ROTOWIRE_API_KEY=

# ── Database ─────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Server ───────────────────────────────────
PORT=3000
MCP_SERVER_NAME=betting-intelligence
TRANSPORT=http

# ── Alerts / Webhooks ──────────────────────
# Discord webhook URL for alerts (Settings > Integrations > Webhooks)
# Example: https://discord.com/api/webhooks/1234567890/abcdef
DISCORD_WEBHOOK_URL=

# Slack webhook URL for alerts (Apps > Incoming Webhooks)
# Get yours at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Optional: Bearer token to protect the /mcp endpoint.
# If set, all MCP requests must include "Authorization: Bearer <token>".
# If not set, the endpoint is open (fine for Railway private networking).
MCP_AUTH_TOKEN=
